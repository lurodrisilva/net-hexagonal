{
  "Features": {
    "//": "Overridden by ConfigMap in Helm deployments. Valid: InboundAdapter=rest|kafka, OutboundAdapter=rest|kafka, Persistence=postgres|mongo, UseRedis=true|false (only with postgres).",
    "InboundAdapter": "rest",
    "OutboundAdapter": "kafka",
    "Persistence": "postgres",
    "UseRedis": true
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Database=hex-scaffold;Username=postgres;Password=postgres;Port=5432"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "hex-scaffold-group"
  },
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "hex-scaffold"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "ExternalApi": {
    "BaseUrl": "https://httpbin.org"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4318"
  },
  "ApplicationInsights": {
    "//": "Prefer the APPLICATIONINSIGHTS_CONNECTION_STRING env var in production.",
    "//2": "Leave blank locally to disable the Azure Monitor sink and fall back to OTLP only.",
    "ConnectionString": ""
  }
}
